{
  "name": "ielts-practice-test",
  "version": "1.0.0",
  "description": "IELTS Starter 1.0 Practice Test System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:fast": "node fast-dev.js",
    "dev:watch": "nodemon --watch server.js --watch public --ext js,json,html,css server.js",
    "dev:debug": "nodemon --inspect server.js",
    "dev:sync": "browser-sync start --config bs-config.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:sync\"",
    "hot": "node dev.js"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "fs-extra": "^11.1.1",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "moment": "^2.29.4",
    "natural": "^8.1.0",
    "path": "^0.12.7",
    "puppeteer": "^21.5.2"
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "concurrently": "^9.2.0",
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "ielts",
    "practice",
    "test",
    "education",
    "english"
  ],
  "author": "IELTS Practice System",
  "license": "MIT"
}
